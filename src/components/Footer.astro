---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

// 取得當前建置時間，並強制轉換為 UTC+8 (台北時間)
const now = new Date();
// 使用 en-US locale 搭配 Asia/Taipei timezone 取得正確的當地時間物件
const utc8Date = new Date(now.toLocaleString("en-US", { timeZone: "Asia/Taipei" }));

const year = utc8Date.getFullYear();
const month = String(utc8Date.getMonth() + 1).padStart(2, '0');
const day = String(utc8Date.getDate()).padStart(2, '0');
const hours = String(utc8Date.getHours()).padStart(2, '0');
const minutes = String(utc8Date.getMinutes()).padStart(2, '0');
const seconds = String(utc8Date.getSeconds()).padStart(2, '0');

const buildTime = `${year}年${month}月${day}日 ${hours}:${minutes}:${seconds} (UTC+8)`;
---
<footer class="footer sm:footer-horizontal items-center flex justify-center bg-base-200 text-base-content p-8 px-10 lg:py-6">
    <nav>
        <p class="text-balance">
            <a href="https://sites.google.com/stu.nknush.kh.edu.tw/ashssa/mac" class="hover:underline">
                國立高雄師範大學附屬高級中學學生會<br class="footer-block">
            </a> 
            2024-{currentYear} All Rights Reserved.
        </p>
        <p class="text-xs">網站最後更新時間：{buildTime}</p>
    </nav>
    <nav class="flex justify-center">
        <div class="join join-vertical">
            <a class="btn btn-ghost join-item break-keep" href="/concentric-law/informations/contact_us">聯絡我們</a>
            <a class="btn btn-ghost join-item break-keep" href="https://ashssa-law-blog.netlify.app/">部落格</a>
            <a class="btn btn-ghost join-item break-keep" href="/concentric-law/informations/sources">Sources</a>
        </div>
    </nav>
</footer>