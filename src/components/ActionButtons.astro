---
// src/components/ActionButtons.astro
// 接收外部傳入的參數
const { url } = Astro.props;

// 設定按鈕預設網址
const defaultUrl = "https://sites.google.com/a/stu.nknush.kh.edu.tw/ashs_sp/laws/修法歷程";

// 決定最終使用的網址：如果有傳入就用傳入的，沒有就用預設的
const finalUrl = url || defaultUrl;
---
<nav class="grid grid-flow-col-3 min-[397px]:grid-flow-col gap-5 md:mx-2 print:hidden my-4">
  <button class="btn btn-neutral" id="backBtn">回上頁</button>
  <a href={finalUrl} target="_blank" class="btn btn-neutral">
    法規沿革
  </a>
  <button class="btn btn-neutral  " id="copyLinkBtn">複製本頁網址</button>
</nav>

<script>
  function initActionButtons() {
    // 處理回上頁
    const backBtn = document.getElementById('backBtn');
    if (backBtn) {
        // 使用 onclick 避免重複綁定
        backBtn.onclick = () => {
            history.back();
        };
    }

    // 處理複製連結
    const copyBtn = document.getElementById('copyLinkBtn');
    if (copyBtn) {
        copyBtn.onclick = async () => {
            try {
                // 執行複製網址 (包含錨點 #article-xx 也會一併複製)
                await navigator.clipboard.writeText(window.location.href);
                
                // 超讚的 UI 視覺回饋：把按鈕變綠色，並改變文字
                const originalText = copyBtn.innerText;
                copyBtn.innerText = '已複製網址　';
                copyBtn.classList.remove('btn-neutral');
                copyBtn.classList.add('btn-active', 'text-success-content'); // DaisyUI 的綠色成功狀態

                // 2 秒後恢復原狀
                setTimeout(() => {
                    copyBtn.innerText = originalText;
                    copyBtn.classList.remove('btn-active', 'text-success-content');
                    copyBtn.classList.add('btn-neutral');
                }, 900);

            } catch (err) {
                console.error('複製失敗:', err);
                alert('複製失敗，請手動複製網頁網址。');
                const originalText = copyBtn.innerText;
                copyBtn.innerText = '複製網址失敗';
                copyBtn.classList.remove('btn-neutral');
                copyBtn.classList.add('btn-active', 'btn-error', 'text-error-content');

                setTimeout(() => {
                  copyBtn.innerText = originalText;
                  copyBtn.classList.remove('btn-active', 'btn-error', 'text-error-content');
                  copyBtn.classList.add('btn-neutral');
                }, 900);

            }
        };
    }
  }

  // === 完美對接 Astro 生命週期 ===
  if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initActionButtons);
  } else {
      initActionButtons();
  }
  
  document.addEventListener('astro:page-load', () => {
      if (document.readyState !== 'loading') initActionButtons();
  });
</script>