---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ActionButtons from '../components/ActionButtons.astro';
import PageSearch from '../components/PageSearch.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import BaseHead from '../components/BaseHead.astro';

const { title } = Astro.props;
---
<html lang="zh-TW">
<head>
    <BaseHead title={title} />
</head>

<body>
    <Navbar />

    <main class="main-content">
        <ActionButtons />
        <div class="law-content">
            <slot />
        </div>

        <PageSearch />
        <ScrollToTop /> 
    </main>
    <Footer />
</body>
</html>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="../scripts/main.js"></script>