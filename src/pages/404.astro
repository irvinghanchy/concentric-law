    <h1 class="text-8xl font-bold text-primary mb-4">404</h1>
    <p class="text-2xl font-bold mb-6">找不到頁面</p>
    <p class="text-base-content/70 mb-8">您尋找的頁面可能已被移除、重新命名或暫時無法使用。</p>
    <button class="btn btn-primary" onclick="history.back()">回上一頁</button>
</div> -->
<!-- </MainLayout> -->
<script>
    // 使用 setTimeout 延遲重新導向，給使用者一點時間看到 "找不到頁面" 的訊息
    setTimeout(function() {
        window.location.href = "/concentric-law";
    }, 1800); // 延遲 1.3 秒 (1300 毫秒)
</script>