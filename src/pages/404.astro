---
// src/pages/404.astro
import BaseHead from '../components/BaseHead.astro';
import MainLayout from '../layouts/MainLayout.astro';
const title  = "找不到頁面 | 404";
const description = "彙編高師大附中學生會所有自治法規的展示網站。";
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <BaseHead title={title} description={description} />
</head>
<body>
<div class="hero bg-base-200 min-h-screen">
    <div class="hero-content text-center">
        <div class="max-w-md">
            <h1 class="text-[10rem]/34 font-bold font--(Noto_Sans) italic pb-2" style="font-family:Noto Sans">404</h1><!-- 本來有：pb-8 underline decoration-primary decoration-wavy -->
            <h2 class="text-5xl font-bold text-base-content/90">找不到頁面</h2>
            <progress class="progress w-58"></progress>
            <p class="py-6">
                不好意思，你好像闖進了時空裂縫！<br>正在努力將你傳送回網站首頁—— <!-- 您試圖存取的頁面錯誤或不存在，將在 1 秒後自動重新導向首頁…… -->
            </p>
        </div>
    </div>
</div>
</body>
</html>
