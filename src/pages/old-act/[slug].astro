---
import { getCollection } from 'astro:content';
import LawLayout from '../../layouts/LawLayout.astro';

export async function getStaticPaths() {
  const oldActs = await getCollection('old-act');
  return oldActs.map(entry => ({
    // 註: 根據 Astro 版本，這裡可能是 entry.slug 或 entry.id
    params: { slug: entry.id || entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
// 使用 Astro 原生的渲染器，它會回傳一個 <Content /> 組件
const { Content } = await entry.render(); 
---

<LawLayout title={entry.data.title} historyUrl={entry.data.historyUrl}>
  
  <main class="main-content">
    
    <h2 class="page-title text-2xl font-bold mb-6 flex items-center gap-3">
        <span class="badge badge-error badge-outline">已廢止</span>
        {entry.data.title}
    </h2>

    <div class="custom-markdown-content bg-base-100 p-6 rounded-box shadow-sm border border-base-200">
        <Content />
    </div>

  </main>
</LawLayout>

